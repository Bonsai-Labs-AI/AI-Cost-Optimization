---
import { MATURITY_LEVELS, CATEGORIES } from '../data/taxonomy.mjs';

interface Tech {
  slug: string;
  title: string;
  category: string;
  maturityLevel: number;
  shortDescription: string;
  status: string;
  href: string;
}
interface Props {
  techniques: Tech[];
}
const { techniques } = Astro.props;

const cellTechs = (lvl: number, cat: string) =>
  techniques.filter((t) => t.maturityLevel === lvl && t.category === cat);
---

<section class="matrix">
  <div class="matrix-filters" id="cat-filters">
    <button class="chip chip-active" data-cat="all">All categories</button>
    {CATEGORIES.map((c) => <button class="chip" data-cat={c.slug}>{c.short}</button>)}
  </div>

  <div class="matrix-scroll">
    <table class="matrix-table" id="matrix-table">
      <thead>
        <tr>
          <th class="corner-cell"></th>
          {CATEGORIES.map((c) => (
            <th class="col-header" data-cat={c.slug}>
              <span class="col-label">{c.short}</span>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {MATURITY_LEVELS.map((tier) => (
          <tr data-level={tier.level}>
            <td class={`level-cell level-l${tier.level}`}>
              <span class="level-tag">L{tier.level}</span>
              <span class="level-name">{tier.name}</span>
              <span class="level-tagline">{tier.tagline}</span>
            </td>
            {CATEGORIES.map((cat) => {
              const items = cellTechs(tier.level, cat.slug);
              return (
                <td class="tech-cell" data-cat={cat.slug}>
                  {items.map((t) => (
                    <button
                      class={`tech-chip level-l${tier.level}${t.status === 'planned' || !t.status ? ' is-planned' : ''}`}
                      data-href={t.href}
                      data-id={`${t.category}/${t.slug}`}
                      data-cat={t.category}
                      title={t.shortDescription}
                    >
                      <span class="tech-dot" />
                      <span class="tech-chip-title">{t.title}</span>
                    </button>
                  ))}
                  {items.length === 0 && <span class="empty-cell">—</span>}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<!-- Technique modal -->
<div class="modal-overlay" id="tech-modal" hidden>
  <div class="modal-backdrop" data-close></div>
  <div class="modal-panel" role="dialog" aria-modal="true" aria-label="Technique detail">
    <div class="modal-bar">
      <a class="modal-fullpage" id="modal-fullpage" href="#">Open full page ↗</a>
      <button class="modal-close" id="modal-close" data-close aria-label="Close">✕</button>
    </div>
    <div class="modal-scroll">
      <div class="modal-body" id="modal-body"></div>
    </div>
  </div>
</div>

<script
  type="application/json"
  id="pyramid-data"
  set:html={JSON.stringify({ techniques })}
/>

<style>
  .matrix { margin: 8px 0 8px; }

  /* ---- Category filter chips ---- */
  .matrix-filters { display: flex; flex-wrap: wrap; gap: 7px; justify-content: center; margin: 0 0 20px; }
  .chip {
    font-size: 0.8rem; padding: 5px 11px; border-radius: 999px; cursor: pointer;
    border: 1px solid var(--border-strong); background: var(--bg-elev); color: var(--text-dim);
    transition: color 0.12s, background 0.12s, border-color 0.12s;
  }
  .chip:hover { color: var(--text); }
  .chip-active { background: var(--accent); color: var(--accent-ink); border-color: var(--accent); font-weight: 600; }

  /* ---- Scrollable table wrapper ---- */
  .matrix-scroll { overflow-x: auto; border-radius: 10px; border: 1px solid var(--border-strong); }

  /* ---- Table skeleton ---- */
  .matrix-table {
    border-collapse: collapse;
    width: 100%;
    min-width: 900px;
    table-layout: fixed;
  }

  /* Corner + column headers */
  .corner-cell { width: 140px; }
  .col-header {
    padding: 9px 10px 8px;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-dim);
    letter-spacing: 0.02em;
    border-bottom: 1px solid var(--border-strong);
    border-left: 1px solid var(--border);
    vertical-align: bottom;
    white-space: normal;
    transition: background 0.15s, color 0.15s;
  }
  .col-header:first-of-type { border-left: none; }
  .col-label { display: block; line-height: 1.3; }

  /* ---- Level row header ---- */
  .level-cell {
    padding: 14px 12px;
    vertical-align: top;
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border-strong);
    border-left: 4px solid var(--tier-color, var(--border));
    background: color-mix(in srgb, var(--tier-color, transparent) 7%, var(--bg-elev));
  }
  .level-l1 { --tier-color: var(--l1); }
  .level-l2 { --tier-color: var(--l2); }
  .level-l3 { --tier-color: var(--l3); }

  .level-tag { display: block; font-family: var(--mono); font-size: 0.78rem; font-weight: 700; color: var(--tier-color); }
  .level-name { display: block; font-weight: 700; font-size: 0.92rem; line-height: 1.2; margin-top: 2px; }
  .level-tagline { display: block; color: var(--text-dim); font-size: 0.75rem; margin-top: 3px; line-height: 1.3; }

  /* ---- Technique cells ---- */
  .tech-cell {
    padding: 8px 9px;
    vertical-align: top;
    border-bottom: 1px solid var(--border);
    border-left: 1px solid var(--border);
    transition: background 0.15s;
  }
  tbody tr:last-child .tech-cell,
  tbody tr:last-child .level-cell { border-bottom: none; }

  .empty-cell { color: var(--text-faint); font-size: 0.8rem; display: block; padding: 2px 0; }

  /* ---- Technique chips (table mode: no category tag) ---- */
  .tech-chip {
    display: block; width: 100%;
    font: inherit; font-size: 0.8rem; cursor: pointer; text-align: left;
    padding: 5px 8px; border-radius: 6px; margin-bottom: 4px;
    border: 1px solid var(--border); background: var(--bg-elev); color: var(--text);
    transition: border-color 0.12s, box-shadow 0.12s, background 0.12s;
    display: flex; align-items: flex-start; gap: 6px;
  }
  .tech-chip:last-child { margin-bottom: 0; }
  .tech-chip:hover { border-color: var(--tier-color, var(--accent)); box-shadow: var(--shadow); background: color-mix(in srgb, var(--tier-color, var(--accent)) 6%, var(--bg-elev)); }
  .tech-chip:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .tech-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--tier-color, var(--accent)); flex: none; margin-top: 5px; }
  .tech-chip-title { line-height: 1.3; }
  .tech-chip.is-planned { border-style: dashed; color: var(--text-dim); }
  .tech-chip.is-planned .tech-dot { opacity: 0.5; }

  /* ---- Category filter: dim/highlight columns ---- */
  .matrix-table.cat-filtered .col-header { color: var(--text-faint); }
  .matrix-table.cat-filtered .col-header.col-active { color: var(--text); background: color-mix(in srgb, var(--accent) 8%, var(--bg-elev)); }
  .matrix-table.cat-filtered .tech-cell { opacity: 0.25; }
  .matrix-table.cat-filtered .tech-cell.col-active { opacity: 1; }

  /* ---- Modal ---- */
  .modal-overlay { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; padding: 24px; }
  .modal-overlay[hidden] { display: none; }
  .modal-backdrop { position: absolute; inset: 0; background: rgba(15, 23, 42, 0.42); backdrop-filter: blur(2px); animation: fade 0.12s ease; }
  .modal-panel {
    position: relative; z-index: 1;
    width: min(820px, 100%); max-height: 90vh;
    display: flex; flex-direction: column;
    background: var(--bg); border: 1px solid var(--border-strong);
    border-radius: 14px; box-shadow: 0 24px 70px rgba(15, 23, 42, 0.28);
    animation: pop 0.14s ease;
  }
  @keyframes fade { from { opacity: 0; } to { opacity: 1; } }
  @keyframes pop { from { opacity: 0; transform: translateY(8px) scale(0.99); } to { opacity: 1; transform: none; } }
  .modal-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px; border-bottom: 1px solid var(--border);
    background: var(--bg-elev); border-radius: 14px 14px 0 0; flex: none;
  }
  .modal-fullpage { font-size: 0.85rem; color: var(--accent); }
  .modal-close {
    width: 30px; height: 30px; border-radius: 8px; cursor: pointer;
    border: 1px solid var(--border-strong); background: var(--bg-elev); color: var(--text-dim);
    font-size: 0.9rem; line-height: 1; display: inline-flex; align-items: center; justify-content: center;
  }
  .modal-close:hover { color: var(--text); border-color: var(--text-faint); }
  .modal-scroll { overflow: auto; padding: 4px 26px 26px; }
  .modal-body { min-height: 80px; }
  .modal-body :global(h1) { font-size: 1.6rem; margin-top: 14px; }
  .modal-loading { color: var(--text-faint); padding: 30px 0; text-align: center; }
</style>

<script>
  import { initCitationPopovers } from '../scripts/citationPopover';

  type Tech = {
    slug: string; title: string; category: string; maturityLevel: number;
    shortDescription: string; status: string; href: string;
  };
  const data = JSON.parse(document.getElementById('pyramid-data')!.textContent || '{}') as {
    techniques: Tech[];
  };

  // ---- Category filter: highlights one column ----
  const table = document.getElementById('matrix-table') as HTMLElement;
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('#cat-filters .chip'));

  function applyFilter(cat: string) {
    if (cat === 'all') {
      table.classList.remove('cat-filtered');
      table.querySelectorAll('.col-active').forEach((el) => el.classList.remove('col-active'));
    } else {
      table.classList.add('cat-filtered');
      table.querySelectorAll('.col-active').forEach((el) => el.classList.remove('col-active'));
      table.querySelectorAll<HTMLElement>(`[data-cat="${cat}"]`).forEach((el) => el.classList.add('col-active'));
    }
  }

  chips.forEach((c) =>
    c.addEventListener('click', () => {
      chips.forEach((x) => x.classList.toggle('chip-active', x === c));
      applyFilter(c.dataset.cat || 'all');
    })
  );

  // ---- Modal ----
  const overlay = document.getElementById('tech-modal') as HTMLElement;
  const body = document.getElementById('modal-body') as HTMLElement;
  const scroll = overlay.querySelector('.modal-scroll') as HTMLElement;
  const fullLink = document.getElementById('modal-fullpage') as HTMLAnchorElement;
  const closeBtn = document.getElementById('modal-close') as HTMLButtonElement;

  const techChips = Array.from(document.querySelectorAll<HTMLButtonElement>('.tech-chip'));

  let teardownCites: (() => void) | null = null;
  let lastFocus: HTMLElement | null = null;
  let reqToken = 0;

  function openModal(href: string, id: string) {
    lastFocus = document.activeElement as HTMLElement;
    fullLink.href = href;
    body.innerHTML = '<p class="modal-loading">Loading…</p>';
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    scroll.scrollTop = 0;
    closeBtn.focus();
    if (location.hash !== `#t/${id}`) history.pushState({ modal: id }, '', `#t/${id}`);
    loadInto(href);
  }

  async function loadInto(href: string) {
    const token = ++reqToken;
    try {
      const res = await fetch(href, { headers: { 'X-Requested-With': 'modal' } });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const html = await res.text();
      if (token !== reqToken) return;
      const doc = new DOMParser().parseFromString(html, 'text/html');
      const main = doc.querySelector('main');
      if (!main) throw new Error('No content');
      const crumb = main.querySelector('p');
      if (crumb && crumb.querySelector('a[href$="/techniques/"]')) crumb.remove();
      main.querySelectorAll('script:not([type="application/json"])').forEach((s) => s.remove());
      teardownCites?.();
      body.innerHTML = main.innerHTML;
      teardownCites = initCitationPopovers(body);
    } catch (err) {
      if (token !== reqToken) return;
      body.innerHTML =
        `<p class="modal-loading">Couldn't load this technique. ` +
        `<a href="${href}">Open the full page instead ↗</a></p>`;
    }
  }

  function closeModal(fromPop = false) {
    if (overlay.hidden) return;
    overlay.hidden = true;
    document.body.style.overflow = '';
    teardownCites?.();
    teardownCites = null;
    body.innerHTML = '';
    reqToken++;
    lastFocus?.focus?.();
    if (!fromPop && location.hash.startsWith('#t/')) history.pushState('', '', location.pathname + location.search);
  }

  techChips.forEach((chip) =>
    chip.addEventListener('click', () => openModal(chip.dataset.href!, chip.dataset.id!))
  );
  overlay.querySelectorAll('[data-close]').forEach((el) =>
    el.addEventListener('click', () => closeModal())
  );
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay.hidden) closeModal();
  });

  function openFromHash(fromPop = false) {
    const m = location.hash.match(/^#t\/(.+)$/);
    if (!m) {
      if (fromPop) closeModal(true);
      return;
    }
    const id = decodeURIComponent(m[1]);
    const chip = techChips.find((c) => c.dataset.id === id);
    if (chip) {
      if (fromPop) {
        fullLink.href = chip.dataset.href!;
        body.innerHTML = '<p class="modal-loading">Loading…</p>';
        overlay.hidden = false;
        document.body.style.overflow = 'hidden';
        loadInto(chip.dataset.href!);
      } else {
        openModal(chip.dataset.href!, id);
      }
    }
  }
  window.addEventListener('popstate', () => openFromHash(true));
  openFromHash();
</script>
